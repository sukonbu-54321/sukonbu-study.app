# =============================================================
# StudyQuest — .gitignore（公開リポジトリ安全設定）
# =============================================================

# ---------------------------------------------------------------
# 🔑 機密情報・認証情報（絶対にコミットしない）
# ---------------------------------------------------------------
# ローカルの Firebase 接続設定（APIキーを含む）
public/config.js

# 環境変数ファイル全般
.env
.env.local
.env.development
.env.production
.env.*.local

# Firebase サービスアカウントキー（Firebase Admin SDK 用）
*-adminsdk-*.json
serviceAccountKey.json
service-account*.json
*serviceaccount*.json

# Google Cloud 認証情報
gcloud-credentials.json
application_default_credentials.json

# ---------------------------------------------------------------
# 🔥 Firebase 関連
# ---------------------------------------------------------------
# Firebase キャッシュ・デプロイ一時ファイル
.firebase/
firebase-debug.log
firebase-debug.*.log
.firebaserc
firebase.json


# Firebase Dataconnect 生成ファイル
.dataconnect

# ※ .firebaserc はプロジェクトIDを含むが、公開リポジトリでは
#   自身のプロジェクトIDが特定される。気になる場合はコメントアウトを解除。
# .firebaserc

# ---------------------------------------------------------------
# 📦 依存関係・パッケージ
# ---------------------------------------------------------------
node_modules/
bower_components/
.npm
.yarn-integrity
*.tgz

# ---------------------------------------------------------------
# 📝 ログファイル
# ---------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------
# 🛠 ビルド・コンパイル成果物
# ---------------------------------------------------------------
build/
dist/
build/Release

# ---------------------------------------------------------------
# 🧪 テスト・カバレッジ
# ---------------------------------------------------------------
coverage/
.nyc_output/

# ---------------------------------------------------------------
# 💻 OS・エディタ固有ファイル
# ---------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Desktop.ini
ehthumbs.db

# VSCode
.vscode/
!.vscode/extensions.json

# JetBrains IDE
.idea/
*.iml

# ---------------------------------------------------------------
# ⚙️ ランタイム・その他
# ---------------------------------------------------------------
pids/
*.pid
*.seed
*.pid.lock
.lock-wscript
lib-cov/
.grunt/
.eslintcache
.node_repl_history

**/config.example.js
**/404.html
